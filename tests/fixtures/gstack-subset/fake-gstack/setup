#!/usr/bin/env bash
set -euo pipefail

skills="$GOALFLIGHT_GSTACK_SKILLS_DIR"
mkdir -p "$skills"
for src in "$GOALFLIGHT_GSTACK_SOURCE"/*; do
  [ -f "$src/SKILL.md" ] || continue
  name="$(basename "$src")"
  rm -rf "$skills/gstack-$name"
  cp -R "$src" "$skills/gstack-$name"
done
cp "$GOALFLIGHT_GSTACK_SOURCE/LICENSE" "$skills/gstack-LICENSE"
