+fn assistant_text_from_screen(text: &str) -> Option<String> {
+    let marker = '⏺';
+    let line = text.lines().find(|line| line.contains(marker))?;
+    let (_, after_marker) = line.split_once(marker)?;
+    let text = after_marker
+        .split(" (")
+        .next()
+        .unwrap_or(after_marker)
+        .trim();
+    if text.is_empty() {
+        None
+    } else {
+        Some(text.to_string())
+    }
+}
