.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Local host install targets (written by setup into user/project paths, not repo canon)
.opencode/
.cursor/

# Local legacy host adapter drafts. Kept out of git to avoid host-name
# scans changing controller billing behavior.
legacy-host-adapters/

# Codex per-project trust mirror — written by scripts/install-codex-overrides.sh.
# Contains absolute paths specific to the local machine; not portable.
.codex/

# Claude Code per-project state: worktrees (auto-managed by `/goal-flight execute --parallel`),
# session state, machine-local memory. None of this is portable or canonical.
.claude/

# Goal Flight local per-dispatch worktrees.
worktrees/

# Goal Flight local runtime state (autoreview handoff temp files, etc.).
# Not portable or canonical; an orphaned handoff here must never enter a
# review bundle (`local_bundle` slurps untracked files) or be git-added.
.goal-flight/

# Python bytecode (from scripts/acp_*.py + test/test_acp_*.py).
__pycache__/
*.pyc

# Manual live-test artifacts (not checked in).
tests/manual/.prompt-matrix-report.json
tests/manual/.prompt-matrix-run.log
tests/manual/.acp-hardening-report.json
tests/manual/.acp-hardening-run.log
.goalflight-acp-*.status.json
codedb.snapshot

# Private per-project runtime state. Fully untracked — init creates directories
# at runtime; never track a skeleton here (tracked exceptions are how private
# content gets force-added by accident).
docs-private/

# Browser-facing live dashboard generated by init/sync. Store artifacts stay in
# docs-private/; this root directory is for easy Finder/bookmark access only.
/dashboard/

# Machine-local operator extensions: site-specific add-ons that are not part of
# the published skill and are loaded at runtime only when present. Fully
# untracked — never git-add anything here. No trailing slash so the rule also
# covers a symlink at this path (the installed skill symlinks scripts/ext here).
scripts/ext
tests/python/ext
