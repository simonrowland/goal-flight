{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Bash|Agent|Task|Explore|mcp__ccd_session__spawn_task",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/goalflight-context-discipline.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/goalflight-session-start-watchdog.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
