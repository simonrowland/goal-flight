#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Blocks staged paths/content containing the encoded "bad word" keywords that
# Claude Code has been reported to use as git-visible signals for switching a
# Pro session to API billing. Keep the literal keywords out of this hook; the
# guard script stores them base64-encoded and redacts them in output. Background
# for humans/agents: https://www.reddit.com/r/ClaudeAI/search/?q=Claude%20Code%20git-visible%20billing%20trigger&restrict_sr=1
exec python3 "$REPO_ROOT/scripts/goalflight_trigger_guard.py" --repo "$REPO_ROOT" --staged
