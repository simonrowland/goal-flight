{
  "schema": "goalflight.agent-adapter.v1",
  "agent_id": "hermes",
  "display_name": "Hermes Host",
  "agent_family": "hermes",
  "providers": {
    "controller_provider": "mixed",
    "model_provider": "mixed",
    "same_provider_policy": "lower_trust_weight"
  },
  "support": {
    "controller": {
      "capability": "supported",
      "evidence": ["plan: Hermes is a goal-flight host adapter target", "contract: host-native orchestration projects through repo-canonical state"],
      "readiness_requirements": ["binary", "version", "auth_optional", "safe_args", "status_contract"],
      "fallback": "worker_only"
    },
    "worker": {
      "capability": "supported",
      "transport": ["acp", "plugin", "tail_file"],
      "readiness_requirements": ["binary", "version", "noninteractive", "status_contract", "safe_args"],
      "fallback": "tail_file"
    }
  },
  "local_readiness_state": {
    "storage": "machine-local, never checked in",
    "path_pattern": "$XDG_STATE_HOME/goal-flight/readiness/<agent>.json",
    "controller": "not_installed",
    "worker": "not_installed",
    "last_probe_ids": ["hermes-path"],
    "updated_at": null
  },
  "live_gate": {
    "function": "validate_adapter_gate",
    "controller_allowed_expr": "support.controller.capability == supported && local_readiness.controller == ready",
    "worker_allowed_expr": "support.worker.capability == supported && local_readiness.worker == ready && requested_transport is verified",
    "default": "deny",
    "support_status_enum": ["unsupported", "config_only", "probe_required", "candidate", "not_installed", "forbidden-arg", "failed", "blocked"],
    "return_fields": ["allowed", "reason", "required_probe_ids", "blocked_fields", "safe_next_action", "live_controller_allowed", "live_worker_dispatch_allowed"]
  },
  "tool_name_map": {
    "shell_exec": {"host_tools": ["Hermes shell bridge"], "constraints": ["safe probes only"]},
    "read_file": {"host_tools": ["Hermes file read"], "constraints": ["workspace reads only"]},
    "write_file": {"host_tools": ["Hermes file write"], "constraints": ["authorized edit scope only"]},
    "search": {"host_tools": ["Hermes search"], "constraints": ["filtered search"]},
    "delegate": {"host_tools": ["Hermes worker queue"], "constraints": ["repo queue/status files remain canonical"]},
    "ask_user": {"host_tools": ["USER-NEED marker"], "constraints": ["block on ambiguity"]},
    "plan_update": {"host_tools": ["Hermes task projection"], "constraints": ["projection is non-canonical"]},
    "memory_search": {"host_tools": ["repo resume notes", "Hermes memory projection"], "constraints": ["repo files remain canonical"]},
    "browser_ui": {"host_tools": ["Hermes browser bridge"], "constraints": ["only when host exposes it"]}
  },
  "invocation": {
    "skill_triggers": ["goal-flight", "Hermes host worker"],
    "commands": ["hermes acp"],
    "exec": {
      "kind": "acp",
      "binary": "hermes",
      "args": ["acp"],
      "arg_policy": {
        "required_safe_args": ["acp"],
        "forbidden_args": ["--yolo", "-y", "--dangerously-*", "--dangerously-bypass-approvals-and-sandbox", "--dangerously-skip-permissions", "--allow-dangerously-skip-permissions", "--always-approve", "--allow-all-tools", "--trust-all-tools", "--auto-approve", "--auto-accept", "--skip-permissions", "--no-sandbox", "--disable-sandbox", "--sandbox-disable"],
        "requires_explicit_justification": ["--bare", "--auto", "--headless-with-approval-bypass"],
        "reject_in": ["invocation", "probes", "generated_wrappers", "checked_in_configs"]
      },
      "stdin": "prompt",
      "cwd_policy": "repo_required",
      "output_contract": {
        "parser": "status_json",
        "completion_detection": "structured_final_event",
        "final_event": "ACP prompt result",
        "final_regex": "Goal complete: (true|false)",
        "exit_code_policy": "mapped",
        "resume_args": [],
        "goal_mode_eligible": true
      }
    }
  },
  "permission_surface": {
    "file_reads": ["workspace files"],
    "file_writes": ["authorized edit scope only"],
    "shell": {"allowed_families": ["safe probes", "test runner"], "forbidden_families": ["permission bypass", "destructive reset", "raw web fetch"]},
    "network": {"allowed": false, "user_gate": true, "notes": "Provider calls are never discovery probes."},
    "browser_ui": {"allowed": true, "user_gate": true, "notes": "Host bridge availability is machine-local."},
    "memory_writes": {"allowed": false, "backend": "repo_files"},
    "plugin_sandbox": {"mode": "narrow", "declared_permissions": ["workspace projection", "worker dispatch"]},
    "auto_approve_detection": {"probes": ["hermes-args-scan"], "strict_fail": true},
    "secrets": ["provider API keys"],
    "irreversible_ops": ["git reset --hard", "force push", "rm -rf"]
  },
  "memory_backend": {
    "canonical": "repo_files",
    "repo_files": [".goal-flight/**"],
    "host_native": {"role": "projection", "backend": "Hermes host memory"},
    "mirror_writeback": false,
    "source_epoch": "goal-flight-0.5.0",
    "snapshot_id": "hermes-host-adapter",
    "migration_lock_required_for_writeback": true,
    "drift_policy": "warn_and_prefer_repo"
  },
  "packaging": {
    "checked_in_wrappers": ["configs/hermes/"],
    "generated_outputs": ["dist/hermes/"],
    "install_actions": [],
    "plugin_manifest": {"supported": true, "path": null, "api_status": "probe_required"},
    "mcp": {"required": false, "servers": []},
    "validation": ["json parse", "schema required groups", "local not_installed gate denies live work"]
  },
  "discovery": {
    "budget": {"max_path_probes": 4, "max_version_probes": 1, "max_help_probes": 1, "max_ms_per_probe": 6000, "max_total_ms_per_agent": 20000, "max_total_ms_all_agents": 90000, "max_stdout_bytes_per_probe": 4096, "max_stderr_bytes_per_probe": 4096, "network_default": "deny", "model_consuming": "forbidden"},
    "probes": [
      {"id": "hermes-path", "class": "path", "argv": ["sh", "-lc", "command -v hermes"], "safe_for_setup": true, "network": false, "model_consuming": false, "env_scrub": true},
      {"id": "hermes-version", "class": "version", "argv": ["hermes", "--version"], "safe_for_setup": true, "network": false, "model_consuming": false, "env_scrub": true}
    ]
  },
  "status_contract": {
    "schema": "goalflight.acp-run.v1",
    "liveness_profile": "remote_api",
    "heartbeat_required": true,
    "dispatcher_owns_heartbeat": true,
    "status_file": ".goal-flight/status/<dispatch_id>.json",
    "transport_instance_id": "hermes:<pid>:<dispatch_id>",
    "seq": "monotonic integer",
    "parser_type": "acp",
    "marker_namespace": "goalflight:<dispatch_id>:<transport>:<seq>",
    "stale_after_s": 180,
    "terminal_states": ["complete", "failed", "blocked", "wedged"]
  },
  "host_projection": {}
}
