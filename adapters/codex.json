{
  "schema": "goalflight.agent-adapter.v1",
  "agent_id": "codex",
  "display_name": "OpenAI Codex CLI",
  "agent_family": "codex",
  "providers": {
    "controller_provider": "openai",
    "model_provider": "openai",
    "same_provider_policy": "forbid_self_review"
  },
  "support": {
    "controller": {
      "capability": "supported",
      "evidence": [
        "survey: codex exec supports noninteractive prompt execution with JSONL output",
        "repo: templates/codex-goal-prompt.md.tpl defines goal-mode prompt shape",
        "probe: codex --version and codex login status are safe local readiness checks"
      ],
      "readiness_requirements": ["binary", "version", "auth_optional", "safe_args", "status_contract"],
      "fallback": "worker_only"
    },
    "worker": {
      "capability": "supported",
      "transport": ["cli_json", "acp", "tail_file"],
      "readiness_requirements": ["binary", "version", "noninteractive", "status_contract", "safe_args"],
      "fallback": "tail_file"
    }
  },
  "local_readiness_state": {
    "storage": "machine-local, never checked in",
    "path_pattern": "$XDG_STATE_HOME/goal-flight/readiness/<agent>.json",
    "controller": "probe_required",
    "worker": "probe_required",
    "last_probe_ids": ["codex-path", "codex-version", "codex-login-status"],
    "updated_at": null
  },
  "live_gate": {
    "function": "validate_adapter_gate",
    "controller_allowed_expr": "support.controller.capability == supported && local_readiness.controller == ready",
    "worker_allowed_expr": "support.worker.capability == supported && local_readiness.worker == ready && requested_transport is verified",
    "default": "deny",
    "support_status_enum": ["unsupported", "config_only", "probe_required", "candidate", "not_installed", "forbidden-arg", "failed", "blocked"],
    "return_fields": ["allowed", "reason", "required_probe_ids", "blocked_fields", "safe_next_action", "live_controller_allowed", "live_worker_dispatch_allowed"]
  },
  "tool_name_map": {
    "shell_exec": {
      "host_tools": ["functions.exec_command", "mcp__context_mode__.ctx_execute", "mcp__context_mode__.ctx_batch_execute"],
      "constraints": ["shell output over 20 lines must use context-mode", "respect sandbox and approval policy"]
    },
    "read_file": {
      "host_tools": ["mcp__context_mode__.ctx_execute_file"],
      "constraints": ["read for analysis through context-mode", "read for edit immediately before scoped patch"]
    },
    "write_file": {
      "host_tools": ["functions.apply_patch"],
      "constraints": ["create or edit only authorized files", "never use context-mode tools to write files"]
    },
    "search": {
      "host_tools": ["mcp__context_mode__.ctx_search", "mcp__context_mode__.ctx_batch_execute"],
      "constraints": ["batch related queries", "prefer code-filtered summaries over raw output"]
    },
    "delegate": {
      "host_tools": ["functions.spawn_agent", "codex exec"],
      "constraints": ["only when explicitly authorized", "scoped worker prompts own disjoint files"]
    },
    "ask_user": {
      "host_tools": ["functions.request_user_input", "USER-NEED marker"],
      "constraints": ["ask only on ambiguity that blocks conservative completion"]
    },
    "plan_update": {
      "host_tools": ["functions.update_plan"],
      "constraints": ["one item in_progress at a time"]
    },
    "memory_search": {
      "host_tools": ["mcp__context_mode__.ctx_search sort=timeline", "Codex memory quick pass"],
      "constraints": ["do not treat memory as current truth without verification"]
    },
    "browser_ui": {
      "host_tools": ["Browser plugin", "Chrome plugin"],
      "constraints": ["use only when browser verification is required"]
    }
  },
  "invocation": {
    "skill_triggers": ["/goal", "goal-flight", "Codex goal-mode worker"],
    "commands": ["codex exec --json -C <repo> -"],
    "exec": {
      "kind": "cli",
      "binary": "codex",
      "action_id": "core.dispatch.execute",
      "args": ["exec", "--json", "-C", "<repo>", "-"],
      "arg_policy": {
        "required_safe_args": ["exec", "--json", "-C", "<repo>"],
        "forbidden_args": ["--yolo", "-y", "--dangerously-*", "--dangerously-bypass-approvals-and-sandbox", "--dangerously-skip-permissions", "--allow-dangerously-skip-permissions", "--always-approve", "--allow-all-tools", "--trust-all-tools", "--auto-approve", "--auto-accept", "--skip-permissions", "--no-sandbox", "--disable-sandbox", "--sandbox-disable"],
        "requires_explicit_justification": ["--bare", "--auto", "--headless-with-approval-bypass"],
        "reject_in": ["invocation", "probes", "generated_wrappers", "checked_in_configs"]
      },
      "stdin": "prompt",
      "cwd_policy": "repo_required",
      "output_contract": {
        "parser": "jsonl",
        "completion_detection": "structured_final_event",
        "final_event": "final assistant message",
        "final_regex": "Goal complete: (true|false)",
        "exit_code_policy": "zero_success",
        "resume_args": ["resume"],
        "goal_mode_eligible": true
      }
    }
  },
  "permission_surface": {
    "file_reads": ["workspace files", "authorized memory quick-pass files"],
    "file_writes": ["authorized edit scope only"],
    "shell": {
      "allowed_families": ["git read/write within user request", "test runner", "safe local probes", "package manager install when requested"],
      "forbidden_families": ["destructive reset", "permission bypass", "raw web fetch", "unchecked long output"]
    },
    "network": {
      "allowed": false,
      "user_gate": true,
      "notes": "Network is disabled by default; use official docs only when OpenAI API facts must be current."
    },
    "browser_ui": {
      "allowed": true,
      "user_gate": false,
      "notes": "Use for local frontend verification when relevant."
    },
    "memory_writes": {
      "allowed": false,
      "backend": "repo_files"
    },
    "plugin_sandbox": {
      "mode": "narrow",
      "declared_permissions": ["filesystem workspace-write", "context-mode analysis", "explicit browser plugin use"]
    },
    "os_sandbox": {
      "supported_profiles": ["off", "read-only", "workspace-write"],
      "default_profile": "off",
      "implementation": "runner:sandbox-exec",
      "platform_supported_profiles": {
        "darwin": ["off", "read-only", "workspace-write"],
        "linux": ["off"],
        "wsl": ["off"],
        "windows": ["off"]
      },
      "notes": "Dispatch-level worker subprocess wrapper. This permits temp and Codex host-state writes while fencing project writes by profile; separate from Codex approval policy and ACP permission escalation."
    },
    "auto_approve_detection": {
      "probes": ["codex-args-scan", "adapter-forbidden-args-scan"],
      "strict_fail": true
    },
    "secrets": ["OPENAI_API_KEY", "CODEX_ACCESS_TOKEN"],
    "irreversible_ops": ["git reset --hard", "force push", "rm -rf", "credential deletion"]
  },
  "memory_backend": {
    "canonical": "repo_files",
    "repo_files": [".goal-flight/**", "prompts/**"],
    "host_native": {
      "role": "advisory",
      "backend": "Codex memory"
    },
    "mirror_writeback": false,
    "source_epoch": "goal-flight-0.5.0",
    "snapshot_id": "codex-reference-manifest",
    "migration_lock_required_for_writeback": true,
    "drift_policy": "warn_and_prefer_repo"
  },
  "packaging": {
    "checked_in_wrappers": [
      ".agents/plugins/marketplace.json",
      "plugins/goal-flight/",
      "templates/codex-goal-prompt.md.tpl"
    ],
    "generated_outputs": ["dist/codex/"],
    "install_actions": [
      {
        "kind": "copy",
        "source": "plugins/goal-flight/skills/goal-flight/SKILL.md",
        "target": "~/.codex/skills/goal-flight/SKILL.md",
        "writes_repo": false,
        "writes_user_config": true,
        "user_gate": true,
        "backup_path": "~/.codex/skills/goal-flight/SKILL.md.goal-flight.bak",
        "rollback": "restore_backup",
        "destinations": ["codex-cli-controller"]
      },
      {
        "kind": "register_plugin",
        "source": ".agents/plugins/marketplace.json",
        "target": "~/.codex/config.toml",
        "writes_repo": false,
        "writes_user_config": true,
        "user_gate": true,
        "backup_path": "~/.codex/config.toml.goal-flight.bak",
        "rollback": "restore_backup",
        "destinations": ["codex-desktop-controller"]
      },
      {
        "kind": "copy_or_merge",
        "source": "configs/codex/config.toml",
        "target": "~/.codex/config.toml",
        "writes_repo": false,
        "writes_user_config": true,
        "user_gate": true,
        "backup_path": "~/.codex/config.toml.goal-flight.bak",
        "rollback": "restore_backup",
        "destinations": ["codex-desktop-controller", "codex-cli-controller"]
      }
    ],
    "plugin_manifest": {
      "supported": true,
      "path": "plugins/goal-flight/.codex-plugin/plugin.json",
      "api_status": "verified"
    },
    "mcp": {
      "required": true,
      "servers": ["context-mode"]
    },
    "validation": ["json parse", "schema required groups", "forbidden args scan", "./tests/run.sh"]
  },
  "setup": {
    "controller_destinations": [
      {
        "id": "codex-desktop-controller",
        "label": "Codex Desktop controller",
        "role": "controller",
        "surface": "desktop",
        "default": true,
        "probe_ids": ["codex-path", "codex-version"],
        "install_action_sources": [
          ".agents/plugins/marketplace.json",
          "configs/codex/config.toml"
        ],
        "commands": [
          "codex plugin marketplace add <goal-flight-repo>",
          "codex plugin add goal-flight@goal-flight"
        ],
        "paths": [
          "~/.codex/config.toml",
          "~/.codex/plugins/cache/goal-flight/goal-flight/<version>/"
        ],
        "requires_restart": true
      },
      {
        "id": "codex-cli-controller",
        "label": "Codex CLI controller",
        "role": "controller",
        "surface": "cli",
        "default": false,
        "probe_ids": ["codex-path", "codex-version"],
        "install_action_sources": [
          "plugins/goal-flight/skills/goal-flight/SKILL.md",
          "configs/codex/config.toml"
        ],
        "commands": ["codex exec --json -C <repo> -"],
        "paths": [
          "~/.codex/config.toml",
          "~/.codex/skills/goal-flight/SKILL.md"
        ],
        "requires_restart": false
      }
    ],
    "worker_destinations": [
      {
        "id": "codex-cli-worker",
        "label": "Codex CLI worker",
        "role": "worker",
        "surface": "cli",
        "default": true,
        "probe_ids": ["codex-path", "codex-version"],
        "install_action_sources": [],
        "commands": ["codex exec --json -C <repo> -"],
        "paths": ["$(command -v codex)"],
        "requires_restart": false
      }
    ],
    "addons": [
      {
        "id": "context-mode",
        "label": "context-mode MCP sandbox",
        "default": true,
        "compatible_destination_ids": [
          "codex-desktop-controller",
          "codex-cli-controller",
          "codex-cli-worker"
        ],
        "install_mode": "setup",
        "commands": ["${GOALFLIGHT_PYTHON} scripts/register-context-mode-codex.py"],
        "paths": ["~/.codex/config.toml", "[mcp_servers.context-mode]"]
      },
      {
        "id": "codedb",
        "label": "codedb MCP code-intelligence",
        "default": true,
        "compatible_destination_ids": [
          "codex-desktop-controller",
          "codex-cli-controller",
          "codex-cli-worker"
        ],
        "install_mode": "setup",
        "commands": ["${GOALFLIGHT_PYTHON} scripts/register-codedb-codex.py"],
        "paths": ["~/.codex/config.toml", "[mcp_servers.codedb]"]
      },
      {
        "id": "gstack",
        "label": "gstack skills",
        "default": true,
        "compatible_destination_ids": [
          "codex-desktop-controller",
          "codex-cli-controller",
          "codex-cli-worker"
        ],
        "install_mode": "init_self_check",
        "commands": ["test -d ~/.gstack/repos/gstack/.agents/skills"],
        "paths": ["~/.gstack", "~/.codex/skills/"]
      },
      {
        "id": "autoreview",
        "label": "autoreview chunk review",
        "default": true,
        "compatible_destination_ids": [
          "codex-desktop-controller",
          "codex-cli-controller",
          "codex-cli-worker"
        ],
        "install_mode": "init_self_check",
        "commands": ["test -x scripts/autoreview.sh"],
        "paths": ["scripts/autoreview.sh", "scripts/autoreview_claude_acp", "~/.cursor/skills/autoreview"]
      }
    ]
  },
  "discovery": {
    "budget": {
      "max_path_probes": 4,
      "max_version_probes": 1,
      "max_help_probes": 1,
      "max_ms_per_probe": 5000,
      "max_total_ms_per_agent": 15000,
      "max_total_ms_all_agents": 90000,
      "max_stdout_bytes_per_probe": 4096,
      "max_stderr_bytes_per_probe": 4096,
      "network_default": "deny",
      "model_consuming": "forbidden"
    },
    "probes": [
      {
        "id": "codex-path",
        "class": "path",
        "argv": ["sh", "-lc", "command -v codex"],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      },
      {
        "id": "codex-version",
        "class": "version",
        "argv": ["codex", "--version"],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      },
      {
        "id": "codex-login-status",
        "class": "auth_status",
        "argv": ["codex", "login", "status"],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      }
    ]
  },
  "status_contract": {
    "schema": "goalflight.acp-run.v1",
    "liveness_profile": "remote_api",
    "heartbeat_required": true,
    "dispatcher_owns_heartbeat": true,
    "status_file": ".goal-flight/status/<dispatch_id>.json",
    "transport_instance_id": "codex:<pid>:<dispatch_id>",
    "seq": "monotonic integer",
    "parser_type": "cli_json",
    "marker_namespace": "goalflight:<dispatch_id>:<transport>:<seq>",
    "stale_after_s": 120,
    "terminal_states": ["complete", "failed", "blocked", "wedged"]
  },
  "host_projection": {}
}
