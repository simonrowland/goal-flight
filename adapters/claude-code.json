{
  "schema": "goalflight.agent-adapter.v1",
  "agent_id": "claude-code",
  "display_name": "Claude Code",
  "agent_family": "claude",
  "providers": {
    "controller_provider": "anthropic",
    "model_provider": "anthropic",
    "same_provider_policy": "forbid_self_review"
  },
  "support": {
    "controller": {
      "capability": "supported",
      "evidence": ["survey: claude -p supports stream-json headless runs", "repo: ACP runner maps claude to claude-code-cli-acp"],
      "readiness_requirements": ["binary", "version", "auth_optional", "safe_args", "status_contract"],
      "fallback": "worker_only"
    },
    "worker": {
      "capability": "supported",
      "transport": ["acp", "cli_json", "tail_file"],
      "readiness_requirements": ["binary", "version", "noninteractive", "status_contract", "safe_args"],
      "fallback": "tail_file"
    }
  },
  "local_readiness_state": {
    "storage": "machine-local, never checked in",
    "path_pattern": "$XDG_STATE_HOME/goal-flight/readiness/<agent>.json",
    "controller": "probe_required",
    "worker": "probe_required",
    "last_probe_ids": ["claude-path", "claude-version", "claude-acp-path"],
    "updated_at": null
  },
  "live_gate": {
    "function": "validate_adapter_gate",
    "controller_allowed_expr": "support.controller.capability == supported && local_readiness.controller == ready",
    "worker_allowed_expr": "support.worker.capability == supported && local_readiness.worker == ready && requested_transport is verified",
    "default": "deny",
    "support_status_enum": ["unsupported", "config_only", "probe_required", "candidate", "not_installed", "forbidden-arg", "failed", "blocked"],
    "return_fields": ["allowed", "reason", "required_probe_ids", "blocked_fields", "safe_next_action", "live_controller_allowed", "live_worker_dispatch_allowed"]
  },
  "tool_name_map": {
    "shell_exec": {"host_tools": ["Bash"], "constraints": ["Claude Code host binding for shell_exec", "sandboxed commands only", "no raw output floods"]},
    "read_file": {"host_tools": ["Read"], "constraints": ["Claude Code host binding for read_file", "workspace reads only"]},
    "write_file": {"host_tools": ["Edit", "Write"], "constraints": ["Claude Code host binding for write_file", "authorized edit scope only"]},
    "search": {"host_tools": ["Grep", "Glob"], "constraints": ["Claude Code host binding for search", "prefer indexed or filtered search"]},
    "delegate": {"host_tools": ["Agent", "Task"], "constraints": ["Claude Code host binding for delegate", "only explicitly authorized delegation"]},
    "ask_user": {"host_tools": ["AskUserQuestion", "USER-NEED marker"], "constraints": ["Claude Code host binding for ask_user", "block on true ambiguity"]},
    "plan_update": {"host_tools": ["TodoWrite"], "constraints": ["Claude Code host binding for plan_update", "keep one active task"]},
    "memory_search": {"host_tools": ["repo resume notes", "host memory"], "constraints": ["Claude Code host binding for memory_search", "repo files remain canonical"]},
    "browser_ui": {"host_tools": ["browser MCP"], "constraints": ["Claude Code host binding for browser_ui", "local UI verification only when needed"]}
  },
  "invocation": {
    "skill_triggers": ["/goal", "goal-flight", "Claude Code worker"],
    "commands": ["claude -p --output-format stream-json"],
    "exec": {
      "kind": "cli",
      "binary": "claude",
      "args": ["-p", "--output-format", "stream-json"],
      "arg_policy": {
        "required_safe_args": ["-p", "--output-format", "stream-json"],
        "forbidden_args": ["--yolo", "-y", "--dangerously-*", "--dangerously-bypass-approvals-and-sandbox", "--dangerously-skip-permissions", "--allow-dangerously-skip-permissions", "--always-approve", "--allow-all-tools", "--trust-all-tools", "--auto-approve", "--auto-accept", "--skip-permissions", "--no-sandbox", "--disable-sandbox", "--sandbox-disable"],
        "requires_explicit_justification": ["--bare", "--auto", "--headless-with-approval-bypass"],
        "reject_in": ["invocation", "probes", "generated_wrappers", "checked_in_configs"]
      },
      "stdin": "prompt",
      "cwd_policy": "repo_required",
      "output_contract": {
        "parser": "jsonl",
        "completion_detection": "structured_final_event",
        "final_event": "result event",
        "final_regex": "Goal complete: (true|false)",
        "exit_code_policy": "zero_success",
        "resume_args": ["--continue", "--resume"],
        "goal_mode_eligible": true
      }
    }
  },
  "permission_surface": {
    "file_reads": ["workspace files"],
    "file_writes": ["authorized edit scope only"],
    "shell": {"allowed_families": ["safe probes", "test runner"], "forbidden_families": ["permission bypass", "destructive reset", "raw web fetch"]},
    "network": {"allowed": false, "user_gate": true, "notes": "Do not consume model or network during discovery."},
    "browser_ui": {"allowed": true, "user_gate": false, "notes": "Local browser checks only."},
    "memory_writes": {"allowed": false, "backend": "repo_files"},
    "plugin_sandbox": {"mode": "narrow", "declared_permissions": ["workspace files", "explicit tools"]},
    "os_sandbox": {"supported_profiles": ["off"], "default_profile": "off", "implementation": "unsupported", "notes": "No verified runner OS sandbox profile for this adapter yet."},
    "auto_approve_detection": {"probes": ["claude-args-scan"], "strict_fail": true},
    "secrets": ["ANTHROPIC_API_KEY"],
    "irreversible_ops": ["git reset --hard", "force push", "rm -rf"]
  },
  "memory_backend": {
    "canonical": "repo_files",
    "repo_files": [".goal-flight/**"],
    "host_native": {"role": "advisory", "backend": "Claude Code memory"},
    "mirror_writeback": false,
    "source_epoch": "goal-flight-0.5.0",
    "snapshot_id": "claude-code-host-adapter",
    "migration_lock_required_for_writeback": true,
    "drift_policy": "warn_and_prefer_repo"
  },
  "packaging": {
    "checked_in_wrappers": [".claude-plugin/plugin.json"],
    "generated_outputs": ["dist/claude-code/"],
    "install_actions": [],
    "plugin_manifest": {"supported": true, "path": ".claude-plugin/plugin.json", "api_status": "verified"},
    "mcp": {"required": false, "servers": []},
    "validation": ["json parse", "schema required groups", "forbidden args scan"]
  },
  "setup": {
    "controller_destinations": [
      {
        "id": "claude-code-controller",
        "label": "Claude Code controller",
        "role": "controller",
        "surface": "cli",
        "default": true,
        "probe_ids": ["claude-path", "claude-version"],
        "install_action_sources": [],
        "commands": ["claude"],
        "paths": ["$(command -v claude)", "~/.claude/skills/goal-flight/SKILL.md"],
        "requires_restart": true
      }
    ],
    "worker_destinations": [
      {
        "id": "claude-cli-worker",
        "label": "Claude Code CLI worker",
        "role": "worker",
        "surface": "cli",
        "default": true,
        "probe_ids": ["claude-path", "claude-version"],
        "install_action_sources": [],
        "commands": ["claude -p --output-format stream-json"],
        "paths": ["$(command -v claude)"],
        "requires_restart": false
      }
    ],
    "addons": [
      {
        "id": "context-mode",
        "label": "context-mode MCP sandbox",
        "default": true,
        "compatible_destination_ids": [
          "claude-code-controller",
          "claude-cli-worker"
        ],
        "install_mode": "init_self_check",
        "commands": ["context-mode --help"],
        "paths": ["~/.claude", "~/.claude/plugins/"]
      },
      {
        "id": "gstack",
        "label": "gstack skills",
        "default": true,
        "compatible_destination_ids": [
          "claude-code-controller",
          "claude-cli-worker"
        ],
        "install_mode": "init_self_check",
        "commands": ["test -d ~/.gstack/repos/gstack/.agents/skills"],
        "paths": ["~/.gstack", "~/.claude/skills/"]
      },
      {
        "id": "autoreview",
        "label": "autoreview chunk review",
        "default": true,
        "compatible_destination_ids": [
          "claude-code-controller",
          "claude-cli-worker"
        ],
        "install_mode": "init_self_check",
        "commands": ["test -x scripts/autoreview.sh"],
        "paths": ["scripts/autoreview.sh", "scripts/autoreview_claude_acp", "~/.cursor/skills/autoreview"]
      }
    ]
  },
  "discovery": {
    "budget": {"max_path_probes": 4, "max_version_probes": 2, "max_help_probes": 1, "max_ms_per_probe": 5000, "max_total_ms_per_agent": 15000, "max_total_ms_all_agents": 90000, "max_stdout_bytes_per_probe": 4096, "max_stderr_bytes_per_probe": 4096, "network_default": "deny", "model_consuming": "forbidden"},
    "probes": [
      {"id": "claude-path", "class": "path", "argv": ["sh", "-lc", "command -v claude"], "safe_for_setup": true, "network": false, "model_consuming": false, "env_scrub": true},
      {"id": "claude-version", "class": "version", "argv": ["claude", "--version"], "safe_for_setup": true, "network": false, "model_consuming": false, "env_scrub": true},
      {"id": "claude-acp-path", "class": "path", "argv": ["sh", "-lc", "command -v claude-code-cli-acp"], "safe_for_setup": true, "network": false, "model_consuming": false, "env_scrub": true}
    ]
  },
  "status_contract": {
    "schema": "goalflight.acp-run.v1",
    "liveness_profile": "remote_api",
    "heartbeat_required": true,
    "dispatcher_owns_heartbeat": true,
    "status_file": ".goal-flight/status/<dispatch_id>.json",
    "transport_instance_id": "claude-code:<pid>:<dispatch_id>",
    "seq": "monotonic integer",
    "parser_type": "cli_json",
    "marker_namespace": "goalflight:<dispatch_id>:<transport>:<seq>",
    "stale_after_s": 120,
    "terminal_states": ["complete", "failed", "blocked", "wedged"]
  },
  "host_projection": {}
}
