{
  "schema": "goalflight.agent-adapter.v1",
  "agent_id": "antigravity",
  "display_name": "Antigravity CLI",
  "agent_family": "antigravity",
  "providers": {
    "controller_provider": "none",
    "model_provider": "google",
    "same_provider_policy": "require_cross_provider_review"
  },
  "support": {
    "controller": {
      "capability": "unsupported",
      "evidence": [
        "survey: Antigravity CLI was not assessed as a verified goal-flight controller",
        "stub: no live local controller probe has been run for this manifest"
      ],
      "readiness_requirements": [],
      "fallback": "unsupported"
    },
    "worker": {
      "capability": "unsupported",
      "transport": [],
      "readiness_requirements": [
        "binary",
        "version",
        "noninteractive",
        "safe_args"
      ],
      "fallback": "unsupported"
    }
  },
  "local_readiness_state": {
    "storage": "machine-local, never checked in",
    "path_pattern": "$XDG_STATE_HOME/goal-flight/readiness/<agent>.json",
    "controller": "unsupported",
    "worker": "probe_required",
    "last_probe_ids": [],
    "updated_at": null
  },
  "live_gate": {
    "function": "validate_adapter_gate",
    "controller_allowed_expr": "support.controller.capability == supported && local_readiness.controller == ready",
    "worker_allowed_expr": "support.worker.capability == supported && local_readiness.worker == ready && requested_transport is verified",
    "default": "deny",
    "support_status_enum": [
      "unsupported",
      "config_only",
      "probe_required",
      "candidate",
      "not_installed",
      "forbidden-arg",
      "failed",
      "blocked"
    ],
    "return_fields": [
      "allowed",
      "reason",
      "required_probe_ids",
      "blocked_fields",
      "safe_next_action",
      "live_controller_allowed",
      "live_worker_dispatch_allowed"
    ]
  },
  "tool_name_map": {
    "shell_exec": {
      "host_tools": [],
      "constraints": [
        "unsupported until headless worker contract is verified"
      ]
    },
    "read_file": {
      "host_tools": [],
      "constraints": [
        "unsupported until headless worker contract is verified"
      ]
    },
    "write_file": {
      "host_tools": [],
      "constraints": [
        "unsupported until headless worker contract is verified"
      ]
    },
    "search": {
      "host_tools": [],
      "constraints": [
        "unsupported until headless worker contract is verified"
      ]
    },
    "delegate": {
      "host_tools": [],
      "constraints": [
        "not mapped for unsupported stub"
      ]
    },
    "ask_user": {
      "host_tools": [],
      "constraints": [
        "controller owns user questions"
      ]
    },
    "plan_update": {
      "host_tools": [],
      "constraints": [
        "controller owns plan state"
      ]
    },
    "memory_search": {
      "host_tools": [],
      "constraints": [
        "repo files remain canonical"
      ]
    },
    "browser_ui": {
      "host_tools": [],
      "constraints": [
        "not mapped for unsupported stub"
      ]
    }
  },
  "invocation": {
    "skill_triggers": [
      "goal-flight worker: antigravity"
    ],
    "commands": [],
    "exec": {
      "kind": "prompt_template",
      "binary": null,
      "args": [],
      "arg_policy": {
        "required_safe_args": [],
        "forbidden_args": [
          "--yolo",
          "-y",
          "--dangerously-*",
          "--dangerously-skip-permissions",
          "--dangerously-allow-all",
          "--dangerously-bypass-approvals-and-sandbox",
          "--allow-dangerously-skip-permissions",
          "--always-approve",
          "--allow-all-tools",
          "--trust-all-tools",
          "--auto-accept",
          "--skip-permissions",
          "--no-sandbox",
          "--disable-sandbox",
          "--sandbox-disable"
        ],
        "requires_explicit_justification": [
          "headless-wrapper",
          "bridge-adapter"
        ],
        "reject_in": [
          "invocation",
          "probes",
          "generated_wrappers",
          "checked_in_configs"
        ]
      },
      "stdin": "none",
      "cwd_policy": "repo_required",
      "output_contract": {
        "parser": "transcript",
        "completion_detection": "unsupported",
        "final_event": null,
        "final_regex": null,
        "exit_code_policy": "ignored_never",
        "resume_args": [],
        "goal_mode_eligible": false
      }
    }
  },
  "permission_surface": {
    "file_reads": [],
    "file_writes": [],
    "shell": {
      "allowed_families": [
        "safe local probes"
      ],
      "forbidden_families": [
        "approval bypass",
        "raw web fetch",
        "destructive reset",
        "unchecked long output"
      ]
    },
    "network": {
      "allowed": false,
      "user_gate": true,
      "notes": "Network denied for unsupported stub readiness probes."
    },
    "browser_ui": {
      "allowed": false,
      "user_gate": true,
      "notes": "No browser mapping verified for this unsupported stub."
    },
    "memory_writes": {
      "allowed": false,
      "backend": "none"
    },
    "plugin_sandbox": {
      "mode": "none",
      "declared_permissions": []
    },
    "auto_approve_detection": {
      "probes": [
        "adapter-forbidden-args-scan"
      ],
      "strict_fail": true
    },
    "secrets": [
      "GOOGLE_API_KEY",
      "GEMINI_API_KEY"
    ],
    "irreversible_ops": [
      "git reset --hard",
      "force push",
      "rm -rf",
      "credential deletion"
    ]
  },
  "memory_backend": {
    "canonical": "repo_files",
    "repo_files": [
      ".goal-flight/**",
      "prompts/**"
    ],
    "host_native": {
      "role": "none",
      "backend": null
    },
    "mirror_writeback": false,
    "source_epoch": "goal-flight-0.5.0",
    "snapshot_id": "antigravity-unsupported-stub",
    "migration_lock_required_for_writeback": true,
    "drift_policy": "warn_and_prefer_repo"
  },
  "packaging": {
    "checked_in_wrappers": [],
    "generated_outputs": [],
    "install_actions": [],
    "plugin_manifest": {
      "supported": false,
      "path": null,
      "api_status": "unsupported"
    },
    "mcp": {
      "required": false,
      "servers": []
    },
    "validation": [
      "json parse",
      "schema required groups",
      "forbidden args scan",
      "./tests/run.sh"
    ]
  },
  "discovery": {
    "budget": {
      "max_path_probes": 1,
      "max_version_probes": 1,
      "max_help_probes": 0,
      "max_ms_per_probe": 5000,
      "max_total_ms_per_agent": 10000,
      "max_total_ms_all_agents": 90000,
      "max_stdout_bytes_per_probe": 4096,
      "max_stderr_bytes_per_probe": 4096,
      "network_default": "deny",
      "model_consuming": "forbidden"
    },
    "probes": [
      {
        "id": "antigravity-path",
        "class": "path",
        "argv": [
          "sh",
          "-lc",
          "command -v antigravity"
        ],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      },
      {
        "id": "antigravity-version",
        "class": "version",
        "argv": [
          "antigravity",
          "--version"
        ],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      }
    ]
  },
  "status_contract": {
    "schema": "goalflight.acp-run.v1",
    "liveness_profile": "remote_api",
    "heartbeat_required": true,
    "dispatcher_owns_heartbeat": true,
    "status_file": ".goal-flight/status/<dispatch_id>.json",
    "transport_instance_id": "antigravity:<pid>:<dispatch_id>",
    "seq": "monotonic integer",
    "parser_type": "bash_tail",
    "marker_namespace": "goalflight:<dispatch_id>:<transport>:<seq>",
    "stale_after_s": 120,
    "terminal_states": [
      "complete",
      "failed",
      "blocked",
      "wedged"
    ]
  },
  "host_projection": {}
}
