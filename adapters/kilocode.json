{
  "schema": "goalflight.agent-adapter.v1",
  "agent_id": "kilocode",
  "display_name": "KiloCode",
  "agent_family": "kilocode",
  "providers": {
    "controller_provider": "none",
    "model_provider": "mixed",
    "same_provider_policy": "require_cross_provider_review"
  },
  "support": {
    "controller": {
      "capability": "unsupported",
      "evidence": [
        "survey: KiloCode was assessed as a worker CLI, not a verified goal-flight controller",
        "stub: no live local controller probe has been run for this manifest"
      ],
      "readiness_requirements": [],
      "fallback": "unsupported"
    },
    "worker": {
      "capability": "candidate",
      "transport": [
        "cli_json",
        "acp",
        "tail_file"
      ],
      "readiness_requirements": [
        "binary",
        "version",
        "noninteractive",
        "status_contract",
        "safe_args"
      ],
      "fallback": "tail_file"
    }
  },
  "local_readiness_state": {
    "storage": "machine-local, never checked in",
    "path_pattern": "$XDG_STATE_HOME/goal-flight/readiness/<agent>.json",
    "controller": "unsupported",
    "worker": "probe_required",
    "last_probe_ids": [],
    "updated_at": null
  },
  "live_gate": {
    "function": "validate_adapter_gate",
    "controller_allowed_expr": "support.controller.capability == supported && local_readiness.controller == ready",
    "worker_allowed_expr": "support.worker.capability == supported && local_readiness.worker == ready && requested_transport is verified",
    "default": "deny",
    "support_status_enum": [
      "unsupported",
      "config_only",
      "probe_required",
      "candidate",
      "not_installed",
      "forbidden-arg",
      "failed",
      "blocked"
    ],
    "return_fields": [
      "allowed",
      "reason",
      "required_probe_ids",
      "blocked_fields",
      "safe_next_action",
      "live_controller_allowed",
      "live_worker_dispatch_allowed"
    ]
  },
  "tool_name_map": {
    "shell_exec": {
      "host_tools": [
        "kilo native tool surface (unverified)"
      ],
      "constraints": [
        "deny until binary/version/noninteractive probes pass",
        "forbid approval-bypass arguments"
      ]
    },
    "read_file": {
      "host_tools": [
        "kilo native tool surface (unverified)"
      ],
      "constraints": [
        "workspace reads only after live gate"
      ]
    },
    "write_file": {
      "host_tools": [
        "kilo native tool surface (unverified)"
      ],
      "constraints": [
        "workspace writes only after live gate",
        "controller keeps status authority"
      ]
    },
    "search": {
      "host_tools": [
        "kilo native tool surface (unverified)"
      ],
      "constraints": [
        "prefer structured output where available"
      ]
    },
    "delegate": {
      "host_tools": [],
      "constraints": [
        "not mapped for gated worker stub"
      ]
    },
    "ask_user": {
      "host_tools": [],
      "constraints": [
        "controller owns user questions"
      ]
    },
    "plan_update": {
      "host_tools": [],
      "constraints": [
        "controller owns plan state"
      ]
    },
    "memory_search": {
      "host_tools": [],
      "constraints": [
        "repo files remain canonical"
      ]
    },
    "browser_ui": {
      "host_tools": [],
      "constraints": [
        "not mapped for gated worker stub"
      ]
    }
  },
  "invocation": {
    "skill_triggers": [
      "goal-flight worker: kilocode"
    ],
    "commands": [
      "kilo run <prompt> --format json"
    ],
    "exec": {
      "kind": "cli",
      "binary": "kilo",
      "args": [
        "run",
        "<prompt>",
        "--format",
        "json"
      ],
      "arg_policy": {
        "required_safe_args": [
          "run",
          "<prompt>",
          "--format",
          "json"
        ],
        "forbidden_args": [
          "--yolo",
          "-y",
          "--dangerously-*",
          "--dangerously-skip-permissions",
          "--dangerously-allow-all",
          "--dangerously-bypass-approvals-and-sandbox",
          "--allow-dangerously-skip-permissions",
          "--always-approve",
          "--allow-all-tools",
          "--trust-all-tools",
          "--auto-accept",
          "--skip-permissions",
          "--no-sandbox",
          "--disable-sandbox",
          "--sandbox-disable"
        ],
        "requires_explicit_justification": [
          "--auto",
          "--continue",
          "--session"
        ],
        "reject_in": [
          "invocation",
          "probes",
          "generated_wrappers",
          "checked_in_configs"
        ]
      },
      "stdin": "prompt",
      "cwd_policy": "repo_required",
      "output_contract": {
        "parser": "status_json",
        "completion_detection": "exit_only",
        "final_event": null,
        "final_regex": "Goal complete: (true|false)",
        "exit_code_policy": "zero_success",
        "resume_args": [
          "--continue",
          "--session"
        ],
        "goal_mode_eligible": false
      }
    }
  },
  "permission_surface": {
    "file_reads": [
      "workspace files after live gate"
    ],
    "file_writes": [
      "workspace files after live gate"
    ],
    "shell": {
      "allowed_families": [
        "safe local probes",
        "agent tool calls after live gate"
      ],
      "forbidden_families": [
        "approval bypass",
        "raw web fetch",
        "destructive reset",
        "unchecked long output"
      ]
    },
    "network": {
      "allowed": false,
      "user_gate": true,
      "notes": "Network denied for stub readiness probes."
    },
    "browser_ui": {
      "allowed": false,
      "user_gate": true,
      "notes": "No browser mapping verified for this worker stub."
    },
    "memory_writes": {
      "allowed": false,
      "backend": "none"
    },
    "plugin_sandbox": {
      "mode": "none",
      "declared_permissions": []
    },
    "auto_approve_detection": {
      "probes": [
        "adapter-forbidden-args-scan"
      ],
      "strict_fail": true
    },
    "secrets": [
      "KILO_API_KEY",
      "OPENAI_API_KEY",
      "ANTHROPIC_API_KEY"
    ],
    "irreversible_ops": [
      "git reset --hard",
      "force push",
      "rm -rf",
      "credential deletion"
    ]
  },
  "memory_backend": {
    "canonical": "repo_files",
    "repo_files": [
      ".goal-flight/**",
      "prompts/**"
    ],
    "host_native": {
      "role": "none",
      "backend": null
    },
    "mirror_writeback": false,
    "source_epoch": "goal-flight-0.5.0",
    "snapshot_id": "kilocode-gated-stub",
    "migration_lock_required_for_writeback": true,
    "drift_policy": "warn_and_prefer_repo"
  },
  "packaging": {
    "checked_in_wrappers": [],
    "generated_outputs": [],
    "install_actions": [],
    "plugin_manifest": {
      "supported": false,
      "path": null,
      "api_status": "unsupported"
    },
    "mcp": {
      "required": false,
      "servers": []
    },
    "validation": [
      "json parse",
      "schema required groups",
      "forbidden args scan",
      "./tests/run.sh"
    ]
  },
  "discovery": {
    "budget": {
      "max_path_probes": 1,
      "max_version_probes": 1,
      "max_help_probes": 1,
      "max_ms_per_probe": 5000,
      "max_total_ms_per_agent": 15000,
      "max_total_ms_all_agents": 90000,
      "max_stdout_bytes_per_probe": 4096,
      "max_stderr_bytes_per_probe": 4096,
      "network_default": "deny",
      "model_consuming": "forbidden"
    },
    "probes": [
      {
        "id": "kilocode-path",
        "class": "path",
        "argv": [
          "sh",
          "-lc",
          "command -v kilo"
        ],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      },
      {
        "id": "kilocode-version",
        "class": "version",
        "argv": [
          "kilo",
          "--version"
        ],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      },
      {
        "id": "kilocode-help",
        "class": "help",
        "argv": [
          "kilo",
          "--help"
        ],
        "safe_for_setup": true,
        "network": false,
        "model_consuming": false,
        "env_scrub": true
      }
    ]
  },
  "status_contract": {
    "schema": "goalflight.acp-run.v1",
    "liveness_profile": "remote_api",
    "heartbeat_required": true,
    "dispatcher_owns_heartbeat": true,
    "status_file": ".goal-flight/status/<dispatch_id>.json",
    "transport_instance_id": "kilocode:<pid>:<dispatch_id>",
    "seq": "monotonic integer",
    "parser_type": "cli_json",
    "marker_namespace": "goalflight:<dispatch_id>:<transport>:<seq>",
    "stale_after_s": 120,
    "terminal_states": [
      "complete",
      "failed",
      "blocked",
      "wedged"
    ]
  },
  "host_projection": {}
}
