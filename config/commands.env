# Generated by goalflight_actions.py commands-env — idempotent, no secrets
# action_count=12
: "${GOALFLIGHT_ROOT:=$HOME/.goal-flight}"
export GF_ACTION_core_capacity_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_capacity.py status --json"
export GF_ACTION_core_dispatch_execute="python3 $GOALFLIGHT_ROOT/scripts/goalflight_acp_run.py "
export GF_ACTION_core_dispatch_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_status.py --json"
export GF_ACTION_core_doctor_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_doctor.py --project-root $GOALFLIGHT_ROOT --json"
export GF_ACTION_core_ledger_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_ledger.py list --json"
export GF_ACTION_core_watch_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_watch.py --help"
export GF_ACTION_fleet_bootstrap_execute="python3 $GOALFLIGHT_ROOT/scripts/goalflight_fleet.py bootstrap --json"
export GF_ACTION_fleet_reconcile_execute="python3 $GOALFLIGHT_ROOT/scripts/goalflight_fleet.py reconcile "
export GF_ACTION_fleet_status_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_fleet.py status"
export GF_ACTION_fleet_steering_execute="python3 $GOALFLIGHT_ROOT/scripts/goalflight_fleet.py steering apply --proposal-id "
export GF_ACTION_fleet_steering_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_fleet.py steering show"
export GF_ACTION_fleet_validate_read="python3 $GOALFLIGHT_ROOT/scripts/goalflight_fleet.py validate"
