#!/usr/bin/env python3
"""Autoreview Grok backend via goal-flight ACP (grok agent stdio).

Drop-in for upstream autoreview's engine path: autoreview passes the review
prompt on stdin and expects structured JSON on stdout.

HARD WRITE FENCE: the review runs under a read-only OS sandbox where it is
enforced (macOS sandbox-exec). grok can read any file but CANNOT write or modify
anything in the repo. Findings are delivered in the chat reply (result_text),
which grok's native ACP returns in full (no TUI-scrape truncation), so there is
no writable handoff path to protect — a kernel-enforced fence, unlike the soft
permission-gate title-allow used by the codex/claude engines. On platforms with
no enforced sandbox (e.g. Linux) the review runs unsandboxed; chat delivery still
works but the read-only boundary is then prompt-instructed only.
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import tempfile
import time
import uuid
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
ACP_RUN = ROOT / "scripts" / "goalflight_acp_run.py"

MAX_RECOVERY_ATTEMPTS = 2


def _parse_json_candidate(text: str) -> dict | None:
    stripped = text.strip()
    if not stripped:
        return None
    try:
        parsed = json.loads(stripped)
    except json.JSONDecodeError:
        parsed = None
    if isinstance(parsed, dict) and "findings" in parsed:
        return parsed
    if isinstance(parsed, dict) and isinstance(parsed.get("structured_output"), dict):
        inner = parsed["structured_output"]
        if "findings" in inner:
            return inner
    fenced = re.findall(r"```(?:json)?\s*(\{.*?\})\s*```", stripped, flags=re.S)
    for block in reversed(fenced):
        try:
            obj = json.loads(block)
        except json.JSONDecodeError:
            continue
        if isinstance(obj, dict) and "findings" in obj:
            return obj
    start = stripped.find("{")
    if start >= 0:
        depth = 0
        in_string = False
        escape = False
        for index, char in enumerate(stripped[start:], start=start):
            if in_string:
                if escape:
                    escape = False
                elif char == "\\":
                    escape = True
                elif char == '"':
                    in_string = False
                continue
            if char == '"':
                in_string = True
                continue
            if char == "{":
                depth += 1
            elif char == "}":
                depth -= 1
                if depth == 0:
                    try:
                        obj = json.loads(stripped[start : index + 1])
                    except json.JSONDecodeError:
                        break
                    if isinstance(obj, dict) and "findings" in obj:
                        return obj
                    break
    for line in reversed(stripped.splitlines()):
        line = line.strip()
        if not line.startswith("{"):
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(obj, dict) and "findings" in obj:
            return obj
    return None


def _read_status(path: Path) -> dict:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    return payload if isinstance(payload, dict) else {}


def _read_only_sandbox_supported() -> bool:
    """True when an enforced read-only OS sandbox is available.

    goal-flight enforces the read-only profile via macOS sandbox-exec; other
    platforms have no enforced backend, so the review runs unsandboxed there
    (chat delivery still works; the read-only boundary becomes prompt-only).
    """
    return sys.platform == "darwin" and shutil.which("sandbox-exec") is not None


def _apply_chat_prompt(prompt: str) -> str:
    """Front the autoreview prompt with chat-delivery instructions.

    The base autoreview prompt already asks for a single JSON object in the
    reply; under the read-only fence the reply is the ONLY delivery channel, so
    reinforce that and pin the path format the validator expects.
    """
    banner = (
        "# Autoreview delivery (read first)\n"
        "Deliver the structured review findings as a SINGLE JSON object in your\n"
        "final reply. You are running READ-ONLY: you may read any file but cannot\n"
        "write or modify anything, so the reply is the only delivery channel.\n"
        "Required keys: findings, overall_correctness, overall_explanation,\n"
        "overall_confidence. Each finding's code_location.file_path must be the\n"
        "exact repo-relative path as shown in the diff header (no leading ./, no\n"
        "absolute path). A short prose lead-in is tolerated, but the complete JSON\n"
        "object MUST be present in your reply.\n\n"
    )
    return banner + prompt


def _chat_recovery_prompt(prior_text: str) -> str:
    excerpt = prior_text.strip()[-12000:]
    context = (
        f"\n\nYour prior reply (extract/repair the JSON from it):\n{excerpt}\n"
        if excerpt
        else ""
    )
    return (
        "Recovery turn: your previous reply did not contain a parseable findings\n"
        "JSON object. Reply with ONLY the single JSON object now — keys: findings,\n"
        "overall_correctness, overall_explanation, overall_confidence. No prose.\n"
        f"{context}"
    )


def _acp_cmd(
    repo: Path,
    *,
    dispatch_id: str,
    prompt_b64: str,
    status_path: Path,
    model: str | None = None,
) -> list[str]:
    cmd = [
        sys.executable,
        str(ACP_RUN),
        "--agent",
        "grok-acp",
        "--cwd",
        str(repo),
        "--dispatch-id",
        dispatch_id,
        "--prompt-id",
        "autoreview",
        "--prompt-b64",
        prompt_b64,
        "--status-json",
        str(status_path),
        "--json",
        # The ~10x headroom over a read-only dispatch's 180s idle is intentional:
        # a thorough adversarial review turn legitimately runs much longer than a
        # quick read-only dispatch. --max-quiet-s is the absolute ceiling.
        "--idle-timeout",
        "1800",
        "--max-quiet-s",
        "3600",
    ]
    # HARD WRITE FENCE: run the review under a read-only OS sandbox where it is
    # enforced (macOS sandbox-exec). grok can read any file but CANNOT write or
    # modify anything — findings come back via chat (result_text), so there is no
    # writable handoff path to protect. This is a kernel-enforced fence, unlike
    # the soft permission-gate title-allow used by the codex/claude engines.
    # Where no enforced sandbox exists (e.g. Linux) the review runs unsandboxed;
    # chat delivery still works but the read-only boundary is prompt-only.
    if _read_only_sandbox_supported():
        cmd.extend(["--os-sandbox", "read-only"])
    # Forward an explicit --model so autoreview's model selection reaches grok;
    # when unset, goalflight_acp_run applies its own grok-acp default.
    if model:
        cmd.extend(["--model", model])
    return cmd


def _terminate_process_group(proc: subprocess.Popen) -> None:
    """Terminate the worker's whole process group, not just the direct child.

    The direct child is goalflight_acp_run.py, which spawns ``grok agent`` as a
    grandchild — killing only the child orphans grok. The child leads its own
    session/group (Popen start_new_session=True), so signalling the group reaps
    the grandchildren too. SIGTERM first, escalate to SIGKILL if it lingers.
    """
    try:
        pgid = os.getpgid(proc.pid)
    except (ProcessLookupError, OSError):
        proc.kill()
        return
    for sig in (signal.SIGTERM, signal.SIGKILL):
        try:
            os.killpg(pgid, sig)
        except (ProcessLookupError, OSError):
            return
        try:
            proc.wait(timeout=5)
            return
        except subprocess.TimeoutExpired:
            continue


def _run_acp(
    repo: Path,
    *,
    dispatch_id: str,
    prompt_text: str,
    model: str | None = None,
) -> tuple[int, dict, str, str]:
    """Run one ACP review session.

    Returns (returncode, final_payload, accepted_text, excerpt_text).

    accepted_text is the turn's result ONLY when it genuinely completed
    (rc == 0 and state == "complete"); a blocked / timed-out / killed turn yields
    "" so it cannot be laundered into a pass. excerpt_text is best-effort context
    (possibly partial, or from a failed turn) used only to build a recovery prompt
    and the final error message — NEVER parsed as the accepted report.
    """
    prompt_b64 = base64.b64encode(prompt_text.encode("utf-8")).decode("ascii")
    env = os.environ.copy()
    env.setdefault("GOALFLIGHT_ACP_LIVE_MATRIX", "1")
    status_fd, status_name = tempfile.mkstemp(prefix="goalflight-autoreview-status-", suffix=".json")
    os.close(status_fd)
    status_path = Path(status_name)
    proc: subprocess.Popen | None = None
    stdout = ""
    stderr = ""
    last_text = ""
    try:
        cmd = _acp_cmd(
            repo,
            dispatch_id=dispatch_id,
            prompt_b64=prompt_b64,
            status_path=status_path,
            model=model,
        )
        proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            env=env,
            start_new_session=True,
        )
        # Poll the status file for the latest text while the turn runs, so the
        # recovery excerpt survives even if stdout ends up empty.
        while proc.poll() is None:
            status = _read_status(status_path)
            last_text = str(
                status.get("result_text") or status.get("text_excerpt") or last_text
            )
            time.sleep(0.1)
        stdout, stderr = proc.communicate(timeout=3600)
    finally:
        if proc is not None and proc.poll() is None:
            _terminate_process_group(proc)
            stdout, stderr = proc.communicate(timeout=30)
        status_path.unlink(missing_ok=True)

    rc = proc.returncode if (proc is not None and proc.returncode is not None) else 1
    payload: dict = {}
    if stdout.strip():
        try:
            loaded = json.loads(stdout)
        except json.JSONDecodeError:
            loaded = None
        if isinstance(loaded, dict):
            payload = loaded
    state = str(payload.get("state") or "")
    completed = rc == 0 and state == "complete"
    # ACCEPTED result: only a genuinely-complete turn. goalflight_acp_run sets
    # `result_text` ONLY on state==complete, whereas `text_excerpt` is written on
    # EVERY terminal state (incl. blocked / idle-timeout / killed). Accepting
    # text_excerpt would launder a failed/cut-off review into a valid-looking
    # pass — so it is used only as recovery context, never as the report.
    accepted = str(payload.get("result_text") or "") if completed else ""
    excerpt = str(payload.get("result_text") or payload.get("text_excerpt") or last_text or "")
    if not completed and not accepted and (stderr or stdout):
        print((stderr or stdout)[-2000:], file=sys.stderr)
    return rc, payload, accepted, excerpt


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--print", action="store_true")
    parser.add_argument("--no-session-persistence", action="store_true")
    parser.add_argument("--output-format")
    parser.add_argument("--json-schema")
    parser.add_argument("--model")
    parser.add_argument("--effort")
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--allowedTools")
    parser.add_argument("--tools")
    args, _ = parser.parse_known_args(argv)

    prompt = sys.stdin.read()
    if not prompt.strip():
        print("autoreview_grok_acp: empty stdin prompt", file=sys.stderr)
        return 1

    repo = Path.cwd()
    if not _read_only_sandbox_supported():
        print(
            "autoreview_grok_acp: no enforced OS sandbox on this platform — the "
            "read-only review fence is prompt-only (grok writes are not "
            "kernel-blocked here).",
            file=sys.stderr,
        )
    prompt_with_delivery = _apply_chat_prompt(prompt)

    dispatch_id = f"autoreview-{uuid.uuid4().hex[:10]}"
    rc, payload, accepted, excerpt = _run_acp(
        repo,
        dispatch_id=dispatch_id,
        prompt_text=prompt_with_delivery,
        model=args.model,
    )
    report = _parse_json_candidate(accepted)
    recovery = 0
    while report is None and recovery < MAX_RECOVERY_ATTEMPTS:
        recovery += 1
        print(
            f"autoreview_grok_acp: turn did not deliver a parseable findings JSON; "
            f"recovery {recovery}/{MAX_RECOVERY_ATTEMPTS}",
            file=sys.stderr,
        )
        recovery_id = f"autoreview-recover-{uuid.uuid4().hex[:10]}"
        rc, payload, accepted, excerpt = _run_acp(
            repo,
            dispatch_id=recovery_id,
            prompt_text=_chat_recovery_prompt(excerpt),
            model=args.model,
        )
        report = _parse_json_candidate(accepted)

    if report is None:
        state = (payload or {}).get("state")
        raise RuntimeError(
            "ACP review did not return parseable findings JSON from a COMPLETE turn "
            f"(state={state!r} rc={rc} recovery_attempts={recovery})\n{excerpt[-2000:]}"
        )

    print(json.dumps(report))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as exc:
        print(f"autoreview_grok_acp: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc
